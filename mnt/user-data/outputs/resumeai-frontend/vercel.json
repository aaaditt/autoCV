{
  "rewrites": [
    { "source": "/pages/(.*)", "destination": "/pages/$1.html" },
    { "source": "/((?!static|pages|favicon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
